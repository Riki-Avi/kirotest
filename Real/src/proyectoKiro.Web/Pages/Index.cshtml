@page
@model IndexModel
@{
    ViewData["Title"] = "Kiro Code Lab - Ejercicios C# con Monaco & Judge0";
}

<div class="app-container">
    <!-- Sidebar Personalidades / Ejercicios -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="brand">
                <div class="brand-icon">⚡</div>
                <h2>Kiro Code Lab</h2>
            </div>
            <button class="btn-icon mobile-close" id="closeSidebarBtn">✕</button>
        </div>

        <div class="personalities-section">
            <div class="section-title-row">
                <h3>Ejercicios & Mentores</h3>
                <button class="btn-add" id="openNewPersonalityModalBtn" title="Crear nuevo ejercicio">+ Nuevo</button>
            </div>
            <p class="section-subtitle">Selecciona un ejercicio para precargar la clase y consultar al mentor IA</p>
            <div class="personalities-list" id="personalitiesList">
                <!-- Dinámico desde JS -->
            </div>
        </div>

        <div class="sidebar-footer">
            <button class="btn-secondary" id="openSettingsModalBtn">
                ⚙️ Configuración (API Keys / Judge0)
            </button>
        </div>
    </aside>

    <!-- Main Workspace (Chat Mentor + Monaco Editor) -->
    <div class="workspace-main">
        <!-- Header Bar -->
        <header class="chat-header">
            <button class="btn-icon mobile-menu-btn" id="openSidebarBtn">☰</button>
            
            <div class="active-personality-info" id="activePersonalityDisplay">
                <span class="active-emoji" id="activeEmoji">🔤</span>
                <div>
                    <h2 id="activeName">Ejercicio 1: Invertir Cadena</h2>
                    <span class="active-desc" id="activeDesc">Clase precargada y mentor listo</span>
                </div>
            </div>

            <div class="header-actions">
                <button class="btn-test" id="runTestsBtn" title="Ejecutar la suite de pruebas automatizadas del ejercicio">
                    🧪 Correr Tests
                </button>
                <button class="btn-run" id="runJudge0Btn" title="Compilar y ejecutar en Judge0 API">
                    ▶ Compilar en Judge0
                </button>
                <button class="btn-outline" id="sendCodeToMentorBtn" title="Enviar el código actual de Monaco al Mentor Gemini">
                    🤖 Revisar con IA
                </button>
                <button class="btn-outline" id="clearChatBtn">🗑️</button>
            </div>
        </header>

        <!-- Split Content: Left Chat Mentor, Right Monaco Editor -->
        <div class="split-view">
            <!-- Left Panel: Gemini Mentor Chat -->
            <div class="chat-panel">
                <div class="panel-header">
                    <span>💬 Tutor & Evaluador IA (Gemini 3.5)</span>
                </div>
                <div class="chat-messages" id="chatMessages">
                    <!-- Mensajes y welcome card dinámicos -->
                </div>

                <footer class="chat-input-container">
                    <form id="chatForm" class="input-form">
                        <textarea 
                            id="messageInput" 
                            placeholder="Escribe o habla por micrófono para consultar al mentor..." 
                            rows="1"
                            required
                        ></textarea>
                        <button type="button" class="btn-mic" id="micBtn" title="Hablar por micrófono">
                            🎙️
                        </button>
                        <button type="submit" class="btn-send" id="sendBtn">
                            <span>Enviar</span>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="22" y1="2" x2="11" y2="13"></line>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                            </svg>
                        </button>
                    </form>
                </footer>
            </div>

            <!-- Right Panel: Monaco Editor & Judge0 Output Console -->
            <div class="editor-panel">
                <div class="panel-header editor-header">
                    <span>📝 Editor de Código C# (Monaco Editor)</span>
                    <div class="editor-actions">
                        <button class="btn-sm" id="resetStarterCodeBtn">↺ Resetear Clase</button>
                    </div>
                </div>

                <!-- Editor Container -->
                <div id="monacoEditorContainer" class="monaco-container"></div>

                <!-- Judge0 Terminal Console Output & Test Suite View -->
                <div class="terminal-panel">
                    <div class="terminal-header">
                        <div class="terminal-tabs">
                            <button class="term-tab active" id="tabConsoleBtn">💻 Consola de Salida</button>
                            <button class="term-tab" id="tabTestsBtn">🧪 Pruebas Automatizadas (<span id="testSummaryBadge">0/0</span>)</button>
                        </div>
                        <span class="status-badge" id="judge0StatusBadge">Esperando ejecución...</span>
                    </div>
                    <div class="terminal-content">
                        <pre class="terminal-output" id="terminalOutput">Haz clic en '▶ Compilar en Judge0' para ejecutar o '🧪 Correr Tests' para validar el ejercicio.</pre>
                        <div class="test-results-container hidden" id="testResultsContainer">
                            <p class="test-placeholder">Presiona <strong>'🧪 Correr Tests'</strong> para validar los casos de prueba del ejercicio.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Crear / Editar Ejercicio / Personalidad -->
<div class="modal-backdrop" id="personalityModal">
    <div class="modal-card">
        <div class="modal-header">
            <h3 id="modalTitle">Crear Nuevo Ejercicio</h3>
            <button class="btn-icon" id="closePersonalityModalBtn">✕</button>
        </div>
        <form id="personalityForm" class="modal-body">
            <input type="hidden" id="editPersonalityId" value="">
            
            <div class="form-row">
                <div class="form-group flex-1">
                    <label for="inputEmoji">Ícono / Emoji</label>
                    <input type="text" id="inputEmoji" placeholder="ej. 🔤" required value="💻">
                </div>
                <div class="form-group flex-3">
                    <label for="inputName">Nombre del Ejercicio</label>
                    <input type="text" id="inputName" placeholder="ej. Ejercicio 4: Estructuras" required>
                </div>
            </div>

            <div class="form-group">
                <label for="inputDescription">Descripción / Enunciado Breve</label>
                <input type="text" id="inputDescription" placeholder="ej. Crea una estructura Alumno..." required>
            </div>

            <div class="form-group">
                <label for="inputStarterCode">Código Inicial de la Clase (C#)</label>
                <textarea id="inputStarterCode" rows="4" placeholder="using System; ..."></textarea>
            </div>

            <div class="form-group">
                <label for="inputInstruction">Reglas & Restricciones para el Mentor</label>
                <textarea id="inputInstruction" rows="3" placeholder="RESTRICCIÓN: No puedes utilizar métodos nativos..."></textarea>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-secondary" id="cancelPersonalityBtn">Cancelar</button>
                <button type="submit" class="btn-primary" id="savePersonalityBtn">Guardar Ejercicio</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Configuración -->
<div class="modal-backdrop" id="settingsModal">
    <div class="modal-card">
        <div class="modal-header">
            <h3>Configuración de APIs</h3>
            <button class="btn-icon" id="closeSettingsModalBtn">✕</button>
        </div>
        <form id="settingsForm" class="modal-body">
            <div class="form-group">
                <label for="customApiKey">Clave API de Gemini</label>
                <input type="password" id="customApiKey" placeholder="Dejar en blanco para usar la del servidor">
            </div>

            <div class="form-group">
                <label for="modelSelect">Modelo de Gemini</label>
                <select id="modelSelect">
                    <option value="gemini-3.5-flash" selected>gemini-3.5-flash</option>
                    <option value="gemini-2.0-flash">gemini-2.0-flash</option>
                </select>
            </div>

            <div class="form-group">
                <label for="customJudge0Url">URL del Servidor Judge0</label>
                <input type="text" id="customJudge0Url" placeholder="https://ce.judge0.com (por defecto)">
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-secondary" id="cancelSettingsBtn">Cancelar</button>
                <button type="submit" class="btn-primary">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>

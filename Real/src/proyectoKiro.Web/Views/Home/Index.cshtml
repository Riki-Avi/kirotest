@{
    ViewData["Title"] = "Bienvenido a Kiro Code Lab";
}

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; text-align: center; padding: 20px;">
    <div style="font-size: 4rem; margin-bottom: 10px;">⚡</div>
    <h1 style="font-size: 3rem; margin-bottom: 15px; font-weight: 700;">Bienvenido a Kiro Code Lab</h1>
    <p style="font-size: 1.2rem; color: var(--text-muted, #aaa); max-width: 650px; margin-bottom: 40px; line-height: 1.6;">
        Plataforma interactiva para aprender y practicar C# con Mentores IA en tiempo real, compilación remota en Judge0 y pruebas automatizadas.
    </p>

    <div style="display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; margin-bottom: 50px;">
        <a href="/editor" class="btn-primary" style="padding: 16px 32px; font-size: 1.1rem; text-decoration: none; border-radius: 10px; font-weight: 600; display: flex; align-items: center; gap: 8px;">
            💻 Entrar al Editor & Ejercicios
        </a>
        <a href="/Auth/Login" class="btn-secondary" style="padding: 16px 32px; font-size: 1.1rem; text-decoration: none; border-radius: 10px; font-weight: 600; display: flex; align-items: center; gap: 8px;">
            🔑 Iniciar Sesión con Google
        </a>
    </div>

    <!-- Features Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; width: 100%; max-width: 900px; text-align: left;">
        <div style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px;">
            <h3 style="margin-top:0; font-size: 1.1rem; color: var(--accent-primary);">🤖 Mentores IA</h3>
            <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom:0;">Pistas progresivas y retroalimentación interactiva con Gemini 3.5.</p>
        </div>

        <div style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px;">
            <h3 style="margin-top:0; font-size: 1.1rem; color: var(--accent-primary);">📝 Monaco Editor</h3>
            <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom:0;">El mismo editor que VS Code en tu navegador con autocompletado.</p>
        </div>

        <div style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px;">
            <h3 style="margin-top:0; font-size: 1.1rem; color: var(--accent-primary);">🧪 Suite de Tests</h3>
            <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom:0;">Validación automatizada de casos de prueba con compilador Judge0.</p>
        </div>
    </div>
</div>
